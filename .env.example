# HamTabV1 — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# --- Server ---
# HTTP port (default: 3000, hostedmode: 8080).
PORT=3000
# HTTPS port for self-signed TLS in lanmode (default: 3443).
HTTPS_PORT=3443
# Bind address (default: 0.0.0.0).
HOST=0.0.0.0

# --- Deployment Mode ---
# Set to any value to force hostedmode behavior (normally auto-detected from PORT=8080).
# HOSTED_MODE=

# --- API Keys ---
# Weather Underground API key for local weather.
WU_API_KEY=
# N2YO satellite tracking API key (https://www.n2yo.com/api/).
N2YO_API_KEY=
# OpenWeatherMap API key for global weather.
OWM_API_KEY=

# --- DX Cluster ---
# DX cluster TCP host override (default: telnet.reversebeacon.net).
DXC_TCP_HOST=
# DX cluster TCP port override (default: 7000).
DXC_TCP_PORT=
# Callsign for DX cluster login.
DXC_CALLSIGN=
# Fallback callsign if DXC_CALLSIGN is not set.
HAMTAB_CALLSIGN=

# --- HamQTH Callsign Lookup ---
# HamQTH username for callsign lookups.
HAMQTH_USER=
# HamQTH password.
HAMQTH_PASS=

# --- Feedback System ---
# Enable GitHub issue creation for user feedback (true/false).
FEEDBACK_RELAY_ENABLED=false
# GitHub personal access token with repo:issue scope for feedback relay.
GITHUB_FEEDBACK_TOKEN=

# --- Admin ---
# Token for the /api/config/env admin endpoint.
CONFIG_ADMIN_TOKEN=

# --- VOACAP ---
# Comma-separated API tokens for VOACAP propagation prediction.
VOACAP_API_TOKENS=
